{
  "manifest_version": 3,
  "name": "AI UM LMS Assistant",
  "version": "1.8",
  "description": "Membantu menjelaskan materi dan tugas dari LMS kampus menggunakan DeepSeek, ChatGPT, Kimi, atau Gemini AI - Auto-read DOCX/XLSX/PPTX/PDF",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://elearning.universitasmandiri.ac.id/*",
    "https://*.universitasmandiri.ac.id/*",
    "https://chat.deepseek.com/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://kimi.moonshot.cn/*",
    "https://*.moonshot.cn/*",
    "https://kimi.com/*",
    "https://www.kimi.com/*",
    "https://*.kimi.com/*",
    "https://gemini.google.com/*",
    "https://*.google.com/*",
    "https://aistudio.google.com/*",
    "https://bard.google.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://cdnjs.cloudflare.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://elearning.universitasmandiri.ac.id/*",
        "https://*.universitasmandiri.ac.id/*"
      ],
      "js": [
        "libs/pdf.js",
        "libs/jszip.min.js",
        "libs/xlsx.full.min.js",
        "libs/mammoth.browser.min.js",
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI - Bantu Tugas LMS",
    "default_icon": {
      "16": "icons/icon16um.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "libs/pdf.worker.js",
        "libs/pdf.js",
        "libs/jszip.min.js",
        "libs/xlsx.full.min.js",
        "libs/mammoth.browser.min.js",
        "icons/*"
      ],
      "matches": [
        "https://elearning.universitasmandiri.ac.id/*",
        "https://*.universitasmandiri.ac.id/*"
      ]
    }
  ]
}